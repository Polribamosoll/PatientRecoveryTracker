# Rename this file to secrets.toml (remove the .example suffix).
# Never commit secrets.toml to git — it is already in .gitignore.

# ── App login ────────────────────────────────────────────────
# Simple single-password auth. Change this to something strong.
APP_PASSWORD = "change_me_please"

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_KEY = "your-anon-public-key"
